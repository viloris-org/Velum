{
  "schema_version": 1,
  "manifest_version": "0.1.0",
  "units": {
    "latency": "ms",
    "rate": "mbit/s",
    "packet_size": "bytes",
    "probability": "ratio"
  },
  "reference_path": {
    "id": "stable-reference",
    "description": "Unimpaired reference path used before and after every fault run.",
    "latency_ms": 30,
    "jitter_ms": 2,
    "rate_mbit_s": 100,
    "packet_loss_ratio": 0.0,
    "mtu_bytes": 1500
  },
  "scenarios": [
    {
      "id": "udp-black-hole",
      "description": "Drop all UDP after an established flow reaches steady state.",
      "trigger_after_ms": 10000,
      "recovery_after_ms": 30000,
      "impairments": [{ "protocol": "udp", "kind": "drop", "probability": 1.0 }]
    },
    {
      "id": "udp-rate-limit",
      "description": "Constrain UDP while leaving TCP capacity unchanged.",
      "trigger_after_ms": 10000,
      "recovery_after_ms": 30000,
      "impairments": [{ "protocol": "udp", "kind": "rate", "rate_mbit_s": 0.25 }]
    },
    {
      "id": "burst-loss",
      "description": "Apply correlated loss to both transports without a complete outage.",
      "trigger_after_ms": 10000,
      "recovery_after_ms": 30000,
      "impairments": [{ "protocol": "all", "kind": "burst_loss", "probability": 0.1, "correlation_ratio": 0.75 }]
    },
    {
      "id": "nat-rebinding",
      "description": "Change the client-side public address and source port mid-flow.",
      "trigger_after_ms": 10000,
      "recovery_after_ms": null,
      "impairments": [{ "protocol": "all", "kind": "source_rebind" }]
    },
    {
      "id": "path-mtu-1280",
      "description": "Reduce path MTU to the IPv6 minimum without fragmentation assistance.",
      "trigger_after_ms": 10000,
      "recovery_after_ms": 30000,
      "impairments": [{ "protocol": "all", "kind": "mtu", "mtu_bytes": 1280 }]
    },
    {
      "id": "tcp-only-network",
      "description": "Model an enterprise or captive path where TCP 443 works and UDP does not.",
      "trigger_after_ms": 0,
      "recovery_after_ms": null,
      "impairments": [{ "protocol": "udp", "kind": "drop", "probability": 1.0 }]
    }
  ]
}
